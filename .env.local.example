# ─────────────────────────────────────────────────────────────────────────────
# העתק קובץ זה ל-.env.local ומלא לפחות מפתח אחד.
#   cp .env.local.example .env.local
# .env.local נשאר רק על המחשב שלך (חסום ב-.gitignore) ולא נשלח ל-GitHub/Vercel.
# באפליקציה החיה ב-Vercel: הגדר את אותם משתנים ב-
#   Vercel Dashboard → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Mapbox (חובה למפה) ──────────────────────────────────────────────────────
# הטוקן מוזן דרך מסך ההתחלה של האפליקציה (localStorage), לא כאן.

# ── ספק ה-AI למדריך הקולי ────────────────────────────────────────────────────
# הגדר לפחות מפתח אחד. אם מוגדרים כמה, נבחר לפי סדר: OpenAI ← Gemini ← Claude,
# אלא אם תגדיר AI_PROVIDER במפורש.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# בחירת ספק מפורשת (אופציונלי): openai | gemini | claude
# AI_PROVIDER=openai

# ── הקראה קולית (TTS) ────────────────────────────────────────────────────────
# ל-Claude אין TTS: אם בחרת Claude לטקסט, הקול יגיע מ-OpenAI (אם יש מפתח),
# אחרת מ-Gemini (אם יש מפתח), אחרת מהדפדפן (speechSynthesis).

# ── Supabase — כניסה עם Google + אזור אישי (אופציונלי) ──────────────────────
# בלי ההגדרות האלה האפליקציה עובדת רגיל, פשוט בלי כפתור התחברות.
# 1. צור פרויקט ב-https://supabase.com (חינם)
# 2. Settings → API: העתק את ה-URL ואת ה-anon public key לכאן
# 3. הרץ את supabase/schema.sql ב-SQL Editor
# 4. Authentication → Providers → Google: הפעל (דורש OAuth client מ-Google Cloud)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── עקיפת מודלים/קולות (אופציונלי — יש ברירות מחדל טובות) ──────────────────────
# OPENAI_TEXT_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=nova            # nova | alloy | shimmer | ...
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE=Kore            # Kore | Puck | Charon | ...
# ANTHROPIC_MODEL=claude-opus-4-8  # claude-haiku-4-5 זול יותר
